<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Profile | SocialHub</title>
  <link rel="stylesheet" href="/css/edit_profile.css">
</head>
<body>

  <%- include("partials/nav.ejs") %>

  <main class="edit-container">

    <div class="edit-card">

      <h2>Edit Profile</h2>
      <p class="subtitle">Update your profile photo, name and bio</p>

      <% if (error) { %>
        <div class="error-box"><%= error %></div>
      <% } %>

      <form action="/edit_profile" method="POST" enctype="multipart/form-data">

        <div class="profile-preview">
          <img 
            src="<%= user.profileImage || '/images/default-profile.png' %>" 
            alt="profile"
          >
        </div>

        <div class="form-group">
          <label for="profileImage">Profile Photo</label>
          <input 
            type="file" 
            id="profileImage" 
            name="profileImage" 
            accept="image/*"
          >
        </div>

        <div class="form-group">
          <label for="name">Username</label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            value="<%= user.name %>"
            required
          >
        </div>

        <div class="form-group">
          <label for="bio">Bio</label>
          <textarea 
            id="bio" 
            name="bio" 
            rows="4"
            placeholder="Write something about yourself..."
          ><%= user.bio || "" %></textarea>
        </div>

        <button type="submit" class="save-btn">Save Changes</button>

        <a href="/profile" class="cancel-btn">Cancel</a>

      </form>

    </div>

  </main>

</body>
</html>